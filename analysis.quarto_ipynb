   "source": [
    "#| echo: false\n",
    "winner_counts = step5_df['winner_source'].value_counts(sort=True)\n",
    "labels  = winner_counts['winner_source'].to_list()\n",
    "values  = winner_counts['count'].to_list()\n",
    "colors  = ['#2980b9', '#8e44ad', '#e67e22', '#16a085']\n",
    "\n",
    "fig = go.Figure(go.Bar(\n",
    "    x=labels, y=values,\n",
    "    marker_color=colors,\n",
    "    text=[f'{v:,}' for v in values],\n",
    "    textposition='outside',\n",
    "))\n",
    "fig.update_layout(\n",
    "    title_text='Step 5 Recognitions by Winning Candidate Source',\n",
    "    xaxis_title='Candidate Source',\n",
    "    yaxis_title='Number of Rows Recognized',\n",
    "    height=400,\n",
    "    margin=dict(t=60, b=40),\n",
    ")\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
