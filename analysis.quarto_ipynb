   "source": [
    "#| echo: false\n",
    "fig3 = go.Figure(go.Bar(\n",
    "    x=['No purchase history\\n(qty = 0)', 'Very low history\\n(qty 1–4)', 'Some history\\n(qty ≥ 5)'],\n",
    "    y=[len(no_ph), len(low_ph), len(some_ph)],\n",
    "    marker_color=['#e74c3c', '#e67e22', '#f39c12'],\n",
    "    text=[f'{len(no_ph):,}<br>({no_ph_pct:.1f}%)',\n",
    "          f'{len(low_ph):,}<br>({low_ph_pct:.1f}%)',\n",
    "          f'{len(some_ph):,}<br>({some_ph_pct:.1f}%)'],\n",
    "    textposition='outside',\n",
    "))\n",
    "fig3.update_layout(\n",
    "    title_text='Unrecognized Rows — Purchase History Depth',\n",
    "    xaxis_title='Purchase History Band',\n",
    "    yaxis_title='Unrecognized Row Count',\n",
    "    height=400,\n",
    "    margin=dict(t=60, b=60),\n",
    ")\n",
    "fig3.show()"
   ]
  },
