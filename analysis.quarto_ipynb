   "source": [
    "#| echo: false\n",
    "top_uoms = (\n",
    "    step5_df\n",
    "    .group_by(['RecognizedUOM', 'RecognizedUOMQuantity'])\n",
    "    .agg(pl.len().alias('count'))\n",
    "    .sort('count', descending=True)\n",
    "    .head(10)\n",
    ")\n",
    "\n",
    "fig2 = go.Figure(go.Bar(\n",
    "    y=[f\"{r['RecognizedUOM']}/{r['RecognizedUOMQuantity']}\" for r in top_uoms.iter_rows(named=True)],\n",
    "    x=top_uoms['count'].to_list(),\n",
    "    orientation='h',\n",
    "    marker_color='#27ae60',\n",
    "    text=[f\"{v:,}\" for v in top_uoms['count'].to_list()],\n",
    "    textposition='outside',\n",
    "))\n",
    "fig2.update_layout(\n",
    "    title_text='Top 10 UOM Assignments by Step 5',\n",
    "    xaxis_title='Number of Rows',\n",
    "    yaxis_title='UOM / Quantity',\n",
    "    height=420,\n",
    "    margin=dict(l=100, t=60),\n",
    "    yaxis=dict(autorange='reversed'),\n",
    ")\n",
    "fig2.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "18ebb678",
   "metadata": {},
   "source": [
    "---\n",
    "\n",
    "## Why Unrecognized Rows Stay Unrecognized"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "987b0fb4",
   "metadata": {},
   "outputs": [],
   "source": [
    "#| echo: false\n",
    "no_ph   = unrecog_df.filter(pl.col('TotalPurchaseQuantity') == 0)\n",
    "low_ph  = unrecog_df.filter((pl.col('TotalPurchaseQuantity') > 0) & (pl.col('TotalPurchaseQuantity') < 5))\n",
    "some_ph = unrecog_df.filter(pl.col('TotalPurchaseQuantity') >= 5)\n",
    "null_or_zero_price = unrecog_df.filter(pl.col('PriceUOM').is_null() | (pl.col('PriceUOM') == 0))\n",
    "\n",
    "no_ph_pct   = 100 * len(no_ph)             / unrecog\n",
    "low_ph_pct  = 100 * len(low_ph)            / unrecog\n",
    "some_ph_pct = 100 * len(some_ph)           / unrecog\n",
    "price_pct   = 100 * len(null_or_zero_price) / unrecog"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ab3f4b99",
   "metadata": {
    "user_expressions": [
     {
      "expression": "f\"{price_pct:.1f}\"",
      "result": {
       "data": {
        "text/plain": "'5.9'"
       },
       "metadata": {},
       "status": "ok"
      }
     },
     {
      "expression": "f\"{len(null_or_zero_price):,}\"",
      "result": {
       "data": {
        "text/plain": "'3,168'"
       },
       "metadata": {},
       "status": "ok"
      }
     }
    ]
   },
   "source": [
    "Three root causes account for nearly all unrecognized rows:\n",
    "\n",
    "### 1. No usable PriceUOM (`{python} f\"{price_pct:.1f}\"` % of unrecognized)\n",
    "\n",
    "Step 5 requires a `PriceUOM` to compute a log-distance.  Rows where `PriceUOM` is null or\n",
    "zero (`{python} f\"{len(null_or_zero_price):,}\"` rows) are immediately ineligible.\n",
    "\n",
    "### 2. Low or zero purchase history"
   ]
  },
