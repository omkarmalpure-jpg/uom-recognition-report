   "metadata": {},
   "outputs": [],
   "source": [
    "#| echo: false\n",
    "dbscan_n  = int(winner_counts.filter(pl.col('winner_source') == 'DBSCAN')['count'][0])\n",
    "known_n   = int(winner_counts.filter(pl.col('winner_source') == 'Known Product UOM')['count'][0])\n",
    "ea1_n     = int(winner_counts.filter(pl.col('winner_source') == 'EA/1 WAP')['count'][0])\n",
    "file_n    = int(winner_counts.filter(pl.col('winner_source') == 'FileUOM WAP')['count'][0])"
   ]
  },
