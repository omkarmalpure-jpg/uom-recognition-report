   "source": [
    "---\n",
    "title: \"Proposed Solutions — Closing the Unrecognized Gap\"\n",
    "format:\n",
    "  html:\n",
    "    toc: true\n",
    "    toc-depth: 3\n",
    "---"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "f1f8b8c3",
   "metadata": {},
   "outputs": [],
   "source": [
    "#| echo: false\n",
    "#| warning: false\n",
    "import polars as pl\n",
    "import plotly.graph_objects as go\n",
    "\n",
    "CSV = '/Users/omkarmalpure/Documents/broadjump_v2/analyze-data/UOM-38552.csv'\n",
    "df = pl.read_csv(CSV, null_values=['', 'NULL'])\n",
    "\n",
    "unrecog_df  = df.filter(pl.col('IsRecognized') == False)\n",
    "total       = len(df)\n",
    "unrecog     = len(unrecog_df)\n",
    "\n",
    "no_ph       = unrecog_df.filter(pl.col('TotalPurchaseQuantity') == 0)\n",
    "low_ph      = unrecog_df.filter((pl.col('TotalPurchaseQuantity') > 0) & (pl.col('TotalPurchaseQuantity') < 5))\n",
    "some_ph     = unrecog_df.filter(pl.col('TotalPurchaseQuantity') >= 5)\n",
    "null_price  = unrecog_df.filter(pl.col('PriceUOM').is_null() | (pl.col('PriceUOM') == 0))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "65facb4a",
