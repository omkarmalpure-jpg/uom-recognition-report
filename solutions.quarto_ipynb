   "source": [
    "#| echo: false\n",
    "solutions = ['A — Agentic Web Search', 'B — Similar-Product Transfer', 'C1 — Widen LOG_EPS', 'C3 — Analyst Escalation Queue']\n",
    "coverage  = [len(no_ph), len(low_ph), int(len(some_ph)*0.4), int(len(some_ph)*0.6)]\n",
    "effort    = [4, 3, 1, 2]\n",
    "\n",
    "fig = go.Figure()\n",
    "fig.add_trace(go.Bar(name='Potential rows recovered', x=solutions, y=coverage, marker_color='#27ae60',\n",
    "                      text=[f'{c:,}' for c in coverage], textposition='outside'))\n",
