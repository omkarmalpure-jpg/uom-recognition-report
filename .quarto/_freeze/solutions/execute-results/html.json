or\":\"white\",\"linecolor\":\"white\",\"minorgridcolor\":\"white\",\"startlinecolor\":\"#2a3f5f\"},\"type\":\"carpet\"}],\"table\":[{\"cells\":{\"fill\":{\"color\":\"#EBF0F8\"},\"line\":{\"color\":\"white\"}},\"header\":{\"fill\":{\"color\":\"#C8D4E3\"},\"line\":{\"color\":\"white\"}},\"type\":\"table\"}],\"barpolar\":[{\"marker\":{\"line\":{\"color\":\"#E5ECF6\",\"width\":0.5},\"pattern\":{\"fillmode\":\"overlay\",\"size\":10,\"solidity\":0.2}},\"type\":\"barpolar\"}],\"pie\":[{\"automargin\":true,\"type\":\"pie\"}]},\"layout\":{\"autotypenumbers\":\"strict\",\"colorway\":[\"#636efa\",\"#EF553B\",\"#00cc96\",\"#ab63fa\",\"#FFA15A\",\"#19d3f3\",\"#FF6692\",\"#B6E880\",\"#FF97FF\",\"#FECB52\"],\"font\":{\"color\":\"#2a3f5f\"},\"hovermode\":\"closest\",\"hoverlabel\":{\"align\":\"left\"},\"paper_bgcolor\":\"white\",\"plot_bgcolor\":\"#E5ECF6\",\"polar\":{\"bgcolor\":\"#E5ECF6\",\"angularaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\"},\"radialaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\"}},\"ternary\":{\"bgcolor\":\"#E5ECF6\",\"aaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\"},\"baxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\"},\"caxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\"}},\"coloraxis\":{\"colorbar\":{\"outlinewidth\":0,\"ticks\":\"\"}},\"colorscale\":{\"sequential\":[[0.0,\"#0d0887\"],[0.1111111111111111,\"#46039f\"],[0.2222222222222222,\"#7201a8\"],[0.3333333333333333,\"#9c179e\"],[0.4444444444444444,\"#bd3786\"],[0.5555555555555556,\"#d8576b\"],[0.6666666666666666,\"#ed7953\"],[0.7777777777777778,\"#fb9f3a\"],[0.8888888888888888,\"#fdca26\"],[1.0,\"#f0f921\"]],\"sequentialminus\":[[0.0,\"#0d0887\"],[0.1111111111111111,\"#46039f\"],[0.2222222222222222,\"#7201a8\"],[0.3333333333333333,\"#9c179e\"],[0.4444444444444444,\"#bd3786\"],[0.5555555555555556,\"#d8576b\"],[0.6666666666666666,\"#ed7953\"],[0.7777777777777778,\"#fb9f3a\"],[0.8888888888888888,\"#fdca26\"],[1.0,\"#f0f921\"]],\"diverging\":[[0,\"#8e0152\"],[0.1,\"#c51b7d\"],[0.2,\"#de77ae\"],[0.3,\"#f1b6da\"],[0.4,\"#fde0ef\"],[0.5,\"#f7f7f7\"],[0.6,\"#e6f5d0\"],[0.7,\"#b8e186\"],[0.8,\"#7fbc41\"],[0.9,\"#4d9221\"],[1,\"#276419\"]]},\"xaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\",\"title\":{\"standoff\":15},\"zerolinecolor\":\"white\",\"automargin\":true,\"zerolinewidth\":2},\"yaxis\":{\"gridcolor\":\"white\",\"linecolor\":\"white\",\"ticks\":\"\",\"title\":{\"standoff\":15},\"zerolinecolor\":\"white\",\"automargin\":true,\"zerolinewidth\":2},\"scene\":{\"xaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2},\"yaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2},\"zaxis\":{\"backgroundcolor\":\"#E5ECF6\",\"gridcolor\":\"white\",\"linecolor\":\"white\",\"showbackground\":true,\"ticks\":\"\",\"zerolinecolor\":\"white\",\"gridwidth\":2}},\"shapedefaults\":{\"line\":{\"color\":\"#2a3f5f\"}},\"annotationdefaults\":{\"arrowcolor\":\"#2a3f5f\",\"arrowhead\":0,\"arrowwidth\":1},\"geo\":{\"bgcolor\":\"white\",\"landcolor\":\"#E5ECF6\",\"subunitcolor\":\"white\",\"showland\":true,\"showlakes\":true,\"lakecolor\":\"white\"},\"title\":{\"x\":0.05},\"mapbox\":{\"style\":\"light\"},\"margin\":{\"b\":0,\"l\":0,\"r\":0,\"t\":30}}},\"annotations\":[{\"align\":\"center\",\"font\":{\"color\":\"#0f172a\",\"family\":\"Space Grotesk, sans-serif\",\"size\":13},\"showarrow\":false,\"text\":\"\\u003cb style=\\\"font-size:20px\\\"\\u003e53,754\\u003c\\u002fb\\u003e\\u003cbr\\u003e\\u003cspan style=\\\"color:#64748b;font-size:11px\\\"\\u003eUnrecognized\\u003c\\u002fspan\\u003e\",\"x\":0.5,\"y\":0.5}],\"font\":{\"family\":\"Inter, sans-serif\",\"color\":\"#334155\"},\"legend\":{\"font\":{\"size\":11},\"orientation\":\"h\",\"yanchor\":\"bottom\",\"y\":-0.18,\"xanchor\":\"center\",\"x\":0.5,\"bgcolor\":\"rgba(0,0,0,0)\"},\"margin\":{\"t\":20,\"b\":80,\"l\":20,\"r\":20},\"paper_bgcolor\":\"white\",\"plot_bgcolor\":\"white\",\"height\":380,\"showlegend\":true},                        {\"responsive\": true}                    ).then(function(){\n                            \nvar gd = document.getElementById('b0ea9a3e-b422-4320-b293-e67eabe7d793');\nvar x = new MutationObserver(function (mutations, observer) {{\n        var display = window.getComputedStyle(gd).display;\n        if (!display || display === 'none') {{\n            console.log([gd, 'removed!']);\n            Plotly.purge(gd);\n            observer.disconnect();\n        }}\n}});\n\n// Listen for the removal of the full notebook cells\nvar notebookContainer = gd.closest('#notebook-container');\nif (notebookContainer) {{\n    x.observe(notebookContainer, {childList: true});\n}}\n\n// Listen for the clearing of the current output cell\nvar outputEl = gd.closest('.output');\nif (outputEl) {{\n    x.observe(outputEl, {childList: true});\n}}\n\n                        })                };            </script>        </div>\n```\n:::\n:::\n\n\n| Root Cause | Rows Affected | Proposed Strategy |\n|:-----------|:-------------:|:------------------|\n| No / zero purchase history | 47 | Solution A — Agentic web search |\n| Very low history (1–4 units) | 31\\,400 | Solution B — Similar-product transfer |\n| Price outside DBSCAN range | 21\\,900 | Solution C — Threshold relaxation |\n\n---\n\n## Solution A — Agentic Web Search\n\n<div class=\"solution-cards\">\n<div class=\"sol-card sol-a\">\n<div class=\"sol-header\">\n  <div class=\"sol-icon\">🤖</div>\n  <div class=\"sol-top\">\n    <div class=\"sol-label\">Solution A · Zero-History Products</div>\n    <div class=\"sol-title\">Agentic Web Search with Citation</div>\n    <div class=\"sol-reach\">Targets <strong>47</strong> rows with no purchase history</div>\n  </div>\n</div>\n<div class=\"sol-body\">\n<p>When a product has no purchase history at all, Step 5 has no anchors. The only signal available is the product description, manufacturer, and catalog number. An agentic pipeline can autonomously enrich these rows:</p>\n<ul class=\"sol-steps\">\n  <li data-n=\"1\"><strong>Query construction</strong> — build a structured search from <code>RecognizedProductDesc</code>, <code>RecognizedManufacturerName</code>, and <code>RecognizedProductCatalogNumber</code>.</li>\n  <li data-n=\"2\"><strong>Search & extract</strong> — agent calls a web search tool or medical-device catalogue API and extracts candidate UOM labels and typical pack sizes.</li>\n  <li data-n=\"3\"><strong>Citation attachment</strong> — every suggestion is stored with its source URL so analysts can verify before accepting.</li>\n  <li data-n=\"4\"><strong>Confidence flagging</strong> — agent rates its own confidence (\"exact catalog number match\" vs. \"description keyword match\"). Low-confidence results require mandatory analyst sign-off before write-back.</li>\n  <li data-n=\"5\"><strong>Feedback loop</strong> — accepted suggestions are written to purchase history so future runs resolve the same products without a search.</li>\n</ul>\n<div class=\"sol-tags\">\n  <span class=\"sol-tag effort-high\">High effort</span>\n  <span class=\"sol-tag\">Requires analyst review</span>\n  <span class=\"sol-tag\">Self-improving over time</span>\n  <span class=\"sol-tag\">Needs prompt fine-tuning</span>\n</div>\n</div>\n</div>\n</div>\n\n---\n\n## Solution B — Similar-Product Transfer\n\n<div class=\"solution-cards\">\n<div class=\"sol-card sol-b\">\n<div class=\"sol-header\">\n  <div class=\"sol-icon\">🔗</div>\n  <div class=\"sol-top\">\n    <div class=\"sol-label\">Solution B · Sparse History Products</div>\n    <div class=\"sol-title\">Purchase History Bridge via Product Similarity</div>\n    <div class=\"sol-reach\">Targets <strong>31\\,400</strong> rows with 1–4 unit history</div>\n  </div>\n</div>\n<div class=\"sol-body\">\n<p>Rather than going to the web, look inside existing purchase history for structurally similar products and borrow their ThresholdV2 clusters as a prior:</p>\n<ul class=\"sol-steps\">\n  <li data-n=\"1\"><strong>Similarity candidates</strong> — find products in the catalogue sharing the same <code>RecognizedManufacturerID</code>, same <code>RecognizedProductTypeID</code>, and similar description tokens (keyword overlap or embedding distance).</li>\n  <li data-n=\"2\"><strong>UOM profile transfer</strong> — the similar product's ThresholdV2 clusters and WAP are borrowed. The proximity scoring in Step 5 runs exactly as normal, using the borrowed thresholds.</li>\n  <li data-n=\"3\"><strong>Downgraded confidence</strong> — the resulting score is multiplied by a transfer discount factor (e.g., 0.80) to signal the assignment is inferred, not directly observed.</li>\n  <li data-n=\"4\"><strong>Analyst review queue</strong> — transferred rows surface in a separate queue for analysts to confirm the analogy is valid before the result propagates.</li>\n</ul>\n<div class=\"sol-tags\">\n  <span class=\"sol-tag effort-med\">Medium effort</span>\n  <span class=\"sol-tag\">Needs similarity criteria co-design with analysts</span>\n  <span class=\"sol-tag\">No external API calls</span>\n</div>\n</div>\n</div>\n</div>\n\n### Key questions for analysts\n\nBefore implementing, these must be answered collaboratively:\n\n- Does same **manufacturer + product type** constitute a strong enough analogy, or are there product categories where this would be systematically misleading?\n- What **discount factor** appropriately penalises borrowed confidence?\n- Are there clinical categories (implants vs. consumables) that require different similarity criteria?\n\n---\n\n## Solution C — Threshold Relaxation\n\n<div class=\"solution-cards\">\n<div class=\"sol-card sol-c\">\n<div class=\"sol-header\">\n  <div class=\"sol-icon\">⚙️</div>\n  <div class=\"sol-top\">\n    <div class=\"sol-label\">Solution C · Price Out-of-Range Products</div>\n    <div class=\"sol-title\">Widen the Proximity Window + Analyst Escalation</div>\n    <div class=\"sol-reach\">Targets <strong>21\\,900</strong> rows with history but score &lt; 0.30</div>\n  </div>\n</div>\n<div class=\"sol-body\">\n<p>These rows have adequate purchase history but the file's <code>PriceUOM</code> lands too far from every DBSCAN cluster. Common causes: supplier price changes, new pack sizes, or unit vs. case mismatches. Two complementary approaches:</p>\n<ul class=\"sol-steps\">\n  <li data-n=\"C1\"><strong>Widen LOG_EPS</strong> — raising <code>LOG_EPS</code> from 0.25 → 0.40 extends the tolerance from ~1.78× to ~2.51× price deviation. This is a global change; must be validated on a hold-out set to measure false-positive impact before deployment.</li>\n  <li data-n=\"C2\"><strong>Price-trend adjustment</strong> — for products with time-stamped history, detect upward/downward price trends and project cluster ranges forward. A product trending $10→$13→$16 is likely ~$19 today; the 12-month-old cluster misses it.</li>\n  <li data-n=\"C3\"><strong>Analyst escalation queue</strong> — rows where the best candidate scores 0.20–0.30 (just below acceptance) are surfaced to analysts with the best DBSCAN candidate and distance from the cluster edge visible. Fast accept/reject with feedback loops back to threshold calibration.</li>\n</ul>\n<div class=\"sol-tags\">\n  <span class=\"sol-tag effort-low\">C1: Low effort (config change)</span>\n  <span class=\"sol-tag effort-low\">C3: Low effort (UI change)</span>\n  <span class=\"sol-tag effort-med\">C2: Medium effort</span>\n</div>\n</div>\n</div>\n</div>\n\n---\n\n## Coverage Comparison\n\n::: {#96795b63 .cell execution_count=3}\n\n::: {.cell-output .cell-output-display}\n```{=html}\n<div>            <script src=\"https://cdnjs.cloudflare.com/ajax/libs/mathjax/2.7.5/MathJax.js?config=TeX-AMS-MML_SVG\"></script><script>if (window.MathJax 