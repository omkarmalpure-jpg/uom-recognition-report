    "#| echo: false\n",
    "recog_df = df.filter(pl.col('IsRecognized') == True)\n",
    "\n",
    "bands   = ['Zero (= 0)', 'Very Low (1–4)', 'Some (5–49)', 'Strong (≥ 50)']\n",
    "def ph_counts(frame):\n",
    "    return [\n",
    "        len(frame.filter(pl.col('TotalPurchaseQuantity') == 0)),\n",
    "        len(frame.filter((pl.col('TotalPurchaseQuantity') > 0) & (pl.col('TotalPurchaseQuantity') < 5))),\n",
    "        len(frame.filter((pl.col('TotalPurchaseQuantity') >= 5) & (pl.col('TotalPurchaseQuantity') < 50))),\n",
    "        len(frame.filter(pl.col('TotalPurchaseQuantity') >= 50)),\n",
    "    ]\n",
    "\n",
    "rec_ph   = ph_counts(recog_df)\n",
    "unrec_ph = ph_counts(unrecog_df)\n",
    "\n",
    "fig_ph = go.Figure()\n",
    "fig_ph.add_trace(go.Bar(\n",
    "    name='Recognized', x=bands, y=rec_ph,\n",
    "    marker=dict(color='#10b981', line=dict(width=0)),\n",
    "    hovertemplate='<b>Recognized — %{x}</b><br>%{y:,} rows<extra></extra>',\n",
    "))\n",
    "fig_ph.add_trace(go.Bar(\n",
    "    name='Unrecognized', x=bands, y=unrec_ph,\n",
    "    marker=dict(color='#ef4444', line=dict(width=0)),\n",
    "    hovertemplate='<b>Unrecognized — %{x}</b><br>%{y:,} rows<extra></extra>',\n",
    "))\n",
    "\n",
    "fig_ph.update_layout(\n",
    "    **{k: v for k, v in LAYOUT.items() if k not in ('xaxis', 'yaxis')},\n",
    "    xaxis=dict(\n",
    "        gridcolor='#f1f5f9', linecolor='#e2e8f0',\n",
    "        tickfont=dict(color='#64748b', size=11), title='Purchase History Band',\n",
    "    ),\n",
    "    yaxis=dict(\n",
    "        gridcolor='#f1f5f9', linecolor='#e2e8f0',\n",
    "        tickfont=dict(color='#64748b', size=11), title='Number of Rows',\n",
    "    ),\n",
    "    barmode='group', bargap=0.25, bargroupgap=0.06,\n",
    "    legend=dict(orientation='h', yanchor='bottom', y=1.02, xanchor='right', x=1,\n",
    "                font=dict(size=11), bgcolor='rgba(0,0,0,0)'),\n",
    "    height=380,\n",
    ")\n",
    "fig_ph.show()"
